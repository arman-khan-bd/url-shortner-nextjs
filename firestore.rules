rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // A user can create, read, and update their own profile.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /urls/{urlId} {
      // Get is public for redirection. List is for owner only.
      allow read: if request.method == 'get' || (request.auth != null && resource.data.userId == request.auth.uid);
      
      // Anyone can create a URL.
      allow create: if true;
      
      // Clicks can be incremented by anyone.
      // Other properties can only be updated by the owner.
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks'])) ||
                      (request.auth != null && resource.data.userId == request.auth.uid);
      
      // Only the owner can delete their own URL.
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /counters/{counterId} {
      allow read: if true;
      allow create: if request.resource.data.count == 10000 && counterId == 'url_counter';
      allow update: if request.resource.data.count == resource.data.count + 1 && counterId == 'url_counter';
    }
  }
}
