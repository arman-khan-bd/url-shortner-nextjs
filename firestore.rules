rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      // Only the authenticated user can read or write their own user document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /urls/{urlId} {
      function isOwner() {
        // resource.data refers to the document's data before the request.
        return request.auth.uid == resource.data.userId;
      }

      // Anyone can GET a single URL for redirection.
      allow get: if true;
      
      // A user can LIST their own URLs. 
      // This rule requires the client query to use `where("userId", "==", uid)`.
      // It implicitly checks that the query is filtering for the currently logged-in user.
      allow list: if request.auth != null && request.auth.uid == request.query.where.value;

      // Anyone can create a URL.
      allow create: if true;
      
      // An update is allowed if it's only incrementing clicks, OR if the user is the owner.
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks'])) || (request.auth != null && isOwner());
      
      // Only the owner can delete their own URL.
      allow delete: if request.auth != null && isOwner();
    }

    match /counters/url_counter {
      // Anyone can read the counter (though it's not used by the client).
      allow read: if true;
      // The counter can only be created with a specific value.
      allow create: if request.resource.data.count == 10000;
      // Updates must be atomic increments of 1.
      allow update: if request.resource.data.count == resource.data.count + 1;
    }
  }
}
