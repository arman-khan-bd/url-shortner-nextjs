rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Create: Any authenticated user can create their own document.
      allow create: if request.auth != null && request.auth.uid == userId;

      // Get: A user can read their own profile. An admin can read any profile.
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Update: A user can update their own profile.
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // List/Delete: Only admins can list or delete users.
      allow list, delete: if isAdmin();
    }

    match /urls/{urlId} {
      // Read: Users can list/get their own URLs. Admins can read all URLs.
      // This is the primary rule for authenticated users viewing data in the dashboard.
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();

      // Get (public): Anyone can GET any URL for public redirection. This rule is
      // combined with the `read` rule's `get` permission. If either is true, GET is allowed.
      allow get: if true;
      
      // Create: Anyone can create a URL.
      allow create: if true;
      
      // Update: Clicks can be incremented by anyone. Other updates only by owner/admin.
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks'])) ||
                      (request.auth != null && (resource.data.userId == request.auth.uid || isAdmin()));
      
      // Delete: Only the owner or an admin can delete.
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /counters/{counterId} {
      allow read: if true;
      allow create: if request.resource.data.count == 10000 && counterId == 'url_counter';
      allow update: if request.resource.data.count == resource.data.count + 1 && counterId == 'url_counter';
    }
  }
}
