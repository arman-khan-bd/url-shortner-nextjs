rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read and update their own profile.
    // User creation happens in a server action after Firebase Auth success.
    match /users/{userId} {
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      // Read: Admins can read any profile, users can read their own.
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      // List/Delete: Only admins
      allow list, delete: if isAdmin();
    }

    // URL mappings can be read by anyone for redirection.
    // Creation can be done by anyone (anonymous).
    // An authenticated user can create URLs and manage their own.
    // An admin can manage any URL.
    match /urls/{shortCode} {
      // Get is public for redirection
      allow get: if true;
      // List is for admins or authenticated users
      allow list: if isAdmin() || request.auth != null;
      
      allow create: if true;
      // Allow update/delete if user is owner or an admin.
      // Clicks are updated via transaction, so we check for that specifically.
      allow update: if (request.auth != null && (resource.data.userId == request.auth.uid || isAdmin())) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']));
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Allow clients to increment the counter.
    match /counters/{counterId} {
      allow read: if true;
      allow create: if request.resource.data.count == 10000 && counterId == 'url_counter';
      allow update: if request.resource.data.count == resource.data.count + 1 && counterId == 'url_counter';
    }
  }
}
