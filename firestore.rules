rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      // Only the authenticated user can read or write their own user document.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /urls/{urlId} {
      // A read is allowed in two cases:
      // 1. For redirection: A single document is being read (`get`). This is for the `/[shortCode]` page.
      // 2. For dashboard lists: The user is authenticated and is the owner of the URL. The client query MUST include `where("userId", "==", request.auth.uid)`.
      allow read: if (request.method == 'get') || (request.auth != null && request.auth.uid == resource.data.userId);
      
      // Allow creation of a URL. If a userId is included, it must match the creator's ID.
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || (request.resource.data.userId == null);
      
      // An update is allowed if it's only incrementing clicks for redirection,
      // OR if the authenticated user is the owner.
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']) && request.resource.data.clicks == resource.data.clicks + 1)
                    || (request.auth != null && resource.data.userId == request.auth.uid);
      
      // Only the owner can delete their own URL.
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /counters/url_counter {
      // Anyone can read the counter (though it's not used by the client).
      allow read: if true;
      // The counter can only be created with a specific value.
      allow create: if request.resource.data.count == 10000;
      // Updates must be atomic increments of 1.
      allow update: if request.resource.data.count == resource.data.count + 1;
    }
  }
}
