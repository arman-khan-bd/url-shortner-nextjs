{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user account.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Url": {
      "title": "URL Mapping",
      "description": "Represents a shortened URL.",
      "type": "object",
      "properties": {
        "longUrl": {
          "type": "string",
          "format": "uri"
        },
        "shortCode": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "clicks": {
          "type": "number"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the link. Can be null for anonymous links."
        }
      },
      "required": ["longUrl", "shortCode", "createdAt", "clicks"]
    },
    "Counter": {
        "title": "Counter",
        "description": "A global counter.",
        "type": "object",
        "properties": {
            "count": {
                "type": "number"
            }
        },
        "required": ["count"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Stores user profiles."
    },
    "/urls/{urlId}": {
      "schema": { "$ref": "#/backend/entities/Url" },
      "description": "Stores the URL mappings. Can be created by anonymous or authenticated users."
    },
    "/counters/{counterId}": {
        "schema": { "$ref": "#/backend/entities/Counter" },
        "description": "Stores global counters."
    }
  }
}
